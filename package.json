{
  "name": "general-app",
  "version": "0.0.1",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "build": "electron-builder --mac",
    "build:all": "electron-builder --mac --linux --win"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "@xmldom/xmldom": "^0.8.12",
    "picomatch": "^4.0.4"
  },
  "build": {
    "appId": "com.general.app",
    "productName": "General App",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "ui/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "ui/**/*"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "notarize": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
